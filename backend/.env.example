APP_ENV=local
LOG_LEVEL=INFO

# ── 프론트엔드 CORS ──────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ── 사주 Agent ───────────────────────────────────────────────────
KAKAO_REST_API_KEY=your_kakao_rest_key_here
SOLAR_PRO_API_KEY=

# ── 전세 진단 LLM ─────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.2

# ── 전세 진단 국토부 API ──────────────────────────────────────────
MOLIT_API_SERVICE_KEY=your_molit_service_key_here

# ── OCR (확장 예정) ───────────────────────────────────────────────
OCR_PROVIDER=local
OCR_API_KEY=
OCR_API_URL=