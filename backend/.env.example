KAKAO_REST_API_KEY=your_kakao_rest_key_here
SOLAR_PRO_API_KEY=
FRONTEND_ORIGIN=http://localhost:5173

# 국토교통부 공공데이터포털 일반 인증키 (Decoding 키)
# 전세 API (RTMSDataSvcAptRent) 호출에 사용된다.
MOLIT_API_SERVICE_KEY=

# 매매 API (RTMSDataSvcAptTrade) 전용 키.
# data.go.kr이 활용신청을 API별로 받으므로 분리가 필요할 수 있다.
# 비어 있으면 MOLIT_API_SERVICE_KEY로 폴백된다 (한 키로 두 API 모두 접근 가능한 경우).
MOLIT_API_TRADE_SERVICE_KEY=